{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "./scripts/build-site",
  "outputDirectory": "dist-site",
  "headers": [
    {
      "source": "/install.sh",
      "headers": [{ "key": "Content-Type", "value": "text/x-shellscript; charset=utf-8" }]
    }
  ],
  "redirects": [
    { "source": "/", "destination": "https://github.com/episki/episki-cli", "permanent": false }
  ]
}
